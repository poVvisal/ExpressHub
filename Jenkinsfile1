pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    environment {
        AWS_ACCESS_KEY_ID                 = "REDACTED-ACCESS-KEY"
        AWS_SECRET_ACCESS_KEY             = "REDACTED-SECRET-KEY"
        AWS_DEFAULT_REGION                = "us-east-1"

        TF_VAR_existing_security_group_id = "sg-0795c0d85a643e9b5"
        TF_VAR_existing_key_name          = "new-key"
        TF_VAR_grafana_password           = "REDACTED-PASSWORD"

        TF_DIR              = "terraform/dev"
        TF_STATE_DIR        = "/var/lib/jenkins/terraform-state/expresshub/dev"
        TF_PLUGIN_CACHE_DIR = "/var/lib/jenkins/.terraform.d/plugin-cache"
        TRIVY_CACHE_DIR     = "/var/lib/jenkins/trivy-cache"

        SONAR_SCANNER_HOME  = tool('sonar-scanner')
        PATH                = "${SONAR_SCANNER_HOME}/bin:${env.PATH}"

        DOCKER_IMAGE_NAME   = "expresshub-app"
        CONTAINER_NAME      = "foodexpress-js"
        APP_PORT            = "5000"
    }

    stages {

        stage('Prepare Persistent Directories') {
            steps {
                sh '''
                    set -e
                    mkdir -p /var/lib/jenkins/terraform-state/expresshub/dev \
                             /var/lib/jenkins/.terraform.d/plugin-cache \
                             /var/lib/jenkins/trivy-cache
                '''
            }
        }

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/poVvisal/ExpressHub.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('jenkins2sonar') {
                    sh '''
                        sonar-scanner \
                          -Dsonar.projectKey=ExpressHub \
                          -Dsonar.projectName=ExpressHub \
                          -Dsonar.sources=.
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    script {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to Quality Gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Trivy Filesystem Scan') {
            steps {
                sh '''
                    docker run --rm \
                      -v $WORKSPACE:/app \
                      aquasec/trivy:latest fs /app \
                      --scanners vuln,secret,misconfig \
                      --exit-code 1 \
                      --severity HIGH,CRITICAL \
                      --ignore-unfixed
                      --skip-dirs terraform 
                '''
            }
        }
        stage('Trivy Filesystem Scan') {
            steps {
                sh '''
                    set -e
                    docker run --rm \
                      -v $TRIVY_CACHE_DIR:/root/.cache/ \
                      -v $WORKSPACE:/app \
                      aquasec/trivy:0.69.3 fs /app \
                      --scanners vuln,secret,misconfig \
                      --exit-code 1 \
                      --severity HIGH,CRITICAL \
                      --ignore-unfixed
                      --skip-dirs terraform \
                      

                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    set -e
                    docker build -t ${DOCKER_IMAGE_NAME}:latest .
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    set -e
                    docker run --rm \
                      -v $TRIVY_CACHE_DIR:/root/.cache/ \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      aquasec/trivy:0.69.3 image ${DOCKER_IMAGE_NAME}:latest \
                      --exit-code 1 \
                      --severity HIGH,CRITICAL \
                      --ignore-unfixed \
                      --format template \
                      --template "@contrib/html.tpl" \
                      -o trivy-report.html

                '''
                archiveArtifacts artifacts: 'trivy-report.html', fingerprint: true
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        set -e
                        echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin
                        docker tag ${DOCKER_IMAGE_NAME}:latest $DOCKER_USERNAME/${DOCKER_IMAGE_NAME}:latest
                        docker push $DOCKER_USERNAME/${DOCKER_IMAGE_NAME}:latest
                    '''
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${env.TF_DIR}") {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Plan & Conditional Apply') {
            steps {
                dir("${env.TF_DIR}") {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Persist Terraform State') {
            steps {
                sh 'echo Persist Terraform State'
            }
        }

        stage('Read EC2 Output') {
            steps {
                sh 'echo Read EC2 Output'
            }
        }

        stage('Deploy to EC2') {
            steps {
                sh 'echo Deploy to EC2'
            }
        }
    }

    post {
        always {
            dir("${env.TF_DIR}") {
                sh '''
                    set +e
                    [ -f terraform.tfstate ] && cp -f terraform.tfstate "$TF_STATE_DIR/terraform.tfstate" || true
                    [ -f terraform.tfstate.backup ] && cp -f terraform.tfstate.backup "$TF_STATE_DIR/terraform.tfstate.backup" || true
                    rm -f tfplan .tf_plan_exit_code
                '''
            }
        }

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed, but Terraform state remains on the Jenkins server.'
        }
    }
}